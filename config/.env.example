# Copy to .env (gitignored). Secrets / machine-specific overrides only.
# Anything here overrides config.yaml via HKJC_ prefixed keys (see hkjc_edge/config.py).

# Override the DB path if you want it elsewhere:
# HKJC_DATABASE_PATH=/absolute/path/to/hkjc.sqlite

# Set a real contact string in your User-Agent (politeness):
# HKJC_HTTP_USER_AGENT=hkjc-edge-research/0.1 (personal research; contact: you@example.com)

# Optional: Kaggle credentials if you use `hkjc import-kaggle` to pull gdaley/hkracing.
# KAGGLE_USERNAME=
# KAGGLE_KEY=
